# Alpaca API (Paper Trading - kostenlos auf alpaca.markets registrieren)
ALPACA_API_KEY=dein_api_key_hier
ALPACA_SECRET_KEY=dein_secret_key_hier

# Webhook Sicherheit (beliebiges Passwort - muss mit config.json übereinstimmen)
WEBHOOK_SECRET=DEIN_GEHEIMES_PASSWORT

# Google Sheets (Service Account JSON Datei)
GOOGLE_CREDENTIALS_FILE=google_credentials.json
